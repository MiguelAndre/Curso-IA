# ── LocalStack — Variables de entorno ────────────────────────────────────────
# Copia este archivo a .env y ajusta los valores según tu entorno
#   cp .env.example .env

# ── Nivel de debug (0 = silencioso, 1 = verbose) ─────────────────────────────
DEBUG=0

# ── Persistencia de recursos entre reinicios ─────────────────────────────────
# 1 = activado (recomendado para desarrollo)
# 0 = desactivado (recursos se borran al reiniciar)
PERSISTENCE=1

# ── Directorio de datos locales ───────────────────────────────────────────────
LOCALSTACK_VOLUME_DIR=./volume

# ── Executor para funciones Lambda ───────────────────────────────────────────
# docker  = ejecuta cada Lambda en un contenedor Docker (recomendado)
# local   = ejecuta en el mismo proceso de LocalStack (más rápido, menos aislamiento)
LAMBDA_EXECUTOR=docker

# ── Auth token (opcional — solo para features Pro) ───────────────────────────
# Obtenlo en: https://app.localstack.cloud/workspace/auth-tokens
LOCALSTACK_AUTH_TOKEN=AQUI-TU-TOKEN
