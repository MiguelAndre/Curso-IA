# Copia este archivo a .env (gitignored) y completá los valores.

# Llave de Anthropic para invocar al sub-agente bajo prueba y a los agentes Persona/Juez.
ANTHROPIC_API_KEY=sk-ant-...

# Modelo por defecto para invocar al sub-agente. Usar el mismo que CLAUDE.md
# tiene como referencia productiva para que el test refleje el comportamiento real.
QA_MODEL=claude-sonnet-4-6

# Modelo para el agente Juez (puede ser más capaz para mejor calibración).
QA_JUDGE_MODEL=claude-opus-4-7

# Ruta absoluta a la carpeta con el golden dataset (FDs históricos anonimizados).
# Por defecto apunta a la carpeta hermana evaluacion/dataset/.
DATASET_DIR=../evaluacion/dataset
