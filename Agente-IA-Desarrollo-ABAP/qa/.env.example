# Copia este archivo a .env (gitignored) y completá los valores si necesitás overrides.
# Por defecto NO se requiere ANTHROPIC_API_KEY: la suite invoca la CLI `claude` y usa
# la suscripción Claude Pro/Max/Enterprise del usuario logueado.

# Path al bash.exe de Git for Windows (requerido para invocar `claude` desde Node en Windows).
# Default usado por el wrapper si esta variable no está seteada:
#   C:\Users\<usuario>\AppData\Local\Programs\Git\bin\bash.exe
# CLAUDE_CODE_GIT_BASH_PATH=C:\Program Files\Git\bin\bash.exe

# Modelo para invocar al sub-agente bajo prueba (Validador, fd-a-td, td-a-codigo).
# Usar el mismo que CLAUDE.md tiene como referencia productiva para que el test refleje
# el comportamiento real.
QA_MODEL=claude-sonnet-4-6

# Modelo para la Persona Consultor (opcional; default toma QA_MODEL).
# QA_PERSONA_MODEL=claude-sonnet-4-6

# Modelo para el agente Juez (puede ser más capaz para mejor calibración).
QA_JUDGE_MODEL=claude-opus-4-7

# Ruta absoluta a la carpeta con el golden dataset (FDs históricos anonimizados).
# Por defecto apunta a la carpeta hermana evaluacion/dataset/.
DATASET_DIR=../evaluacion/dataset

# (Opcional · fallback W3) API key de Anthropic. Sólo necesaria si se decide volver al
# SDK directo en lugar del wrapper CLI. Hoy ningún archivo de la suite la lee.
# ANTHROPIC_API_KEY=sk-ant-...
