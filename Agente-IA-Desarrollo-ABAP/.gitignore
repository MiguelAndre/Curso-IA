# Outputs del agente (TDs y códigos por requerimiento)
# Pueden contener información sensible (datos reales, autorizaciones, lógica interna)
# No se versionan — el plan de evaluación y la auditoría operan sobre archivos locales
outputs/

# Dataset de evaluación pre-piloto (FDs y código de producción anonimizados, pero igual sensibles)
evaluacion/

# Archivos temporales del SO y editores
.DS_Store
Thumbs.db
*.swp
*.bak
*~
.vscode/
.idea/

# Estado local de Claude Code (permisos otorgados por usuario en esta máquina)
.claude/settings.local.json

# Terraform — estado local y plan; tfvars con valores sensibles
# Nota: .terraform.lock.hcl SÍ se versiona para fijar versiones de provider.
infra/.terraform/
infra/terraform.tfstate
infra/terraform.tfstate.backup
infra/*.tfplan
infra/.terraform.tfvars.local
infra/*.auto.tfvars
crash.log
crash.*.log
